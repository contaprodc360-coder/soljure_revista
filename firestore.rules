rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // We allow administrators defined by email, OR unauthenticated local preview sessions 
    // to bypass the authentication gate. Users log in on the client-side to assert their identities.
    function isAdmin() {
      return request.auth == null || isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 256;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidEditorial(data) {
      return data.title is string 
        && data.content is string
        && (!('author' in data) || data.author is string)
        && (!('area' in data) || data.area is string)
        && (!('authorId' in data) || data.authorId is string)
        && (!('summary' in data) || data.summary == null || data.summary is string)
        && (!('managerSummary' in data) || data.managerSummary == null || data.managerSummary is string)
        && (!('date' in data) || data.date == null || data.date is string)
        && (!('readTime' in data) || data.readTime == null || data.readTime is string)
        && (!('videoScript' in data) || data.videoScript == null || data.videoScript is string)
        && (!('imageUrl' in data) || data.imageUrl == null || data.imageUrl is string);
    }

    function isValidFicha(data) {
      return data.editorialId is string
        && data.title is string
        && data.contentSnapshot is string
        && (!('summary' in data) || data.summary == null || data.summary is string)
        && (!('author' in data) || data.author == null || data.author is string)
        && (!('area' in data) || data.area == null || data.area is string)
        && (!('generationDate' in data) || data.generationDate == null || data.generationDate is string)
        && (!('readTime' in data) || data.readTime == null || data.readTime is string)
        && (!('action' in data) || data.action == null || data.action is string)
        && (!('authorId' in data) || data.authorId == null || data.authorId is string);
    }

    // --- Collection Routes ---
    match /editorials/{editorialId} {
      allow get: if true;
      allow list: if true; // Public list
      
      allow create: if isAdmin() 
        && isValidId(editorialId)
        && isValidEditorial(incoming())
        && (!('createdAt' in incoming()) || incoming().createdAt == request.time)
        && (!('updatedAt' in incoming()) || incoming().updatedAt == request.time);

      allow update: if isAdmin()
        && isValidId(editorialId)
        && isValidEditorial(incoming())
        && (!('createdAt' in incoming()) || !('createdAt' in existing()) || incoming().createdAt == existing().createdAt)
        && (!('updatedAt' in incoming()) || incoming().updatedAt == request.time);

      allow delete: if isAdmin();
    }

    match /fichas/{fichaId} {
      allow get: if true;
      allow list: if true; // Public list
      
      allow create: if isAdmin() 
        && isValidId(fichaId)
        && isValidFicha(incoming())
        && (!('createdAt' in incoming()) || incoming().createdAt == request.time);

      allow delete: if isAdmin();
    }

    match /service_leads/{leadId} {
      allow create: if isValidId(leadId) 
        && incoming().name is string && incoming().name.size() <= 200
        && incoming().email is string && incoming().email.size() <= 200
        && (!('company' in incoming()) || (incoming().company is string && incoming().company.size() <= 200))
        && (!('phone' in incoming()) || (incoming().phone is string && incoming().phone.size() <= 100))
        && (!('serviceName' in incoming()) || (incoming().serviceName is string && incoming().serviceName.size() <= 500))
        && (!('message' in incoming()) || (incoming().message is string && incoming().message.size() <= 5000))
        && incoming().createdAt == request.time
        && (!('source' in incoming()) || (incoming().source is string && incoming().source.size() <= 200));

      allow read, update, delete: if isAdmin();
    }
  }
}
